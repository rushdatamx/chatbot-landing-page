---
const checkoutUrl = "https://pay.hotmart.com/R104883023O?bid=1773453606789";

const steps = [
  {
    number: "1",
    title: "Copia y Pega",
    description: "Tomas el código y los templates que te doy, los pegas en las plataformas, y cambias los datos de ejemplo por los de tu negocio.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
    </svg>`
  },
  {
    number: "2",
    title: "Conecta",
    description: "Conectas 5 herramientas entre sí siguiendo los videos paso a paso. Solo copiar URLs, pegar claves, y hacer clic en \"Activar\".",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
    </svg>`
  },
  {
    number: "3",
    title: "Lanza",
    description: "Activas tu número de WhatsApp, pruebas que todo funcione, y empiezas a recibir clientes. En 14 días tienes un chatbot vendiendo por ti.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
    </svg>`
  }
];
---

<section id="como-funciona" class="py-16 md:py-24 bg-secondary-900 relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.4&quot;%3E%3Ccircle cx=&quot;30&quot; cy=&quot;30&quot; r=&quot;4&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        El Sistema en 3 Pasos
      </h2>
      <p class="text-xl text-white/80 max-w-2xl mx-auto">
        No necesitas programar. Solo seguir los videos paso a paso.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-3 gap-8 mb-12">
      {steps.map((step, index) => (
        <div class="relative">
          {/* Connector line */}
          {index < steps.length - 1 && (
            <div class="hidden md:block absolute top-12 left-1/2 w-full h-0.5 bg-white/20">
              <div class="absolute right-0 top-1/2 -translate-y-1/2 w-3 h-3 border-t-2 border-r-2 border-primary-400/60 rotate-45"></div>
            </div>
          )}

          <div class="relative bg-white/10 backdrop-blur-sm rounded-2xl p-8 text-center hover:bg-white/15 transition-all duration-300">
            {/* Step number */}
            <div class="w-16 h-16 mx-auto bg-primary-500 text-white rounded-full flex items-center justify-center text-2xl font-bold mb-6 shadow-lg">
              {step.number}
            </div>

            {/* Icon */}
            <div class="w-14 h-14 mx-auto bg-white/10 rounded-xl flex items-center justify-center text-white mb-4">
              <Fragment set:html={step.icon} />
            </div>

            {/* Content */}
            <h3 class="text-xl font-semibold text-white mb-3">
              {step.title}
            </h3>
            <p class="text-white/70">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center">
      <a
        href={checkoutUrl}
        target="_blank"
        rel="noopener noreferrer"
        onclick={`trackInitiateCheckout(); setTimeout(function(){window.open('${checkoutUrl}','_blank')}, 300); return false;`}
        class="inline-flex items-center gap-3 bg-primary-500 hover:bg-primary-600 text-white font-bold px-10 py-5 rounded-full text-xl transition-all duration-300 hover:scale-105 shadow-2xl hover:shadow-primary-500/30"
      >
        Empezar Ahora
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
      <p class="mt-4 text-white/60 text-sm">
        Acceso inmediato. Empieza hoy mismo.
      </p>
    </div>
  </div>
</section>
