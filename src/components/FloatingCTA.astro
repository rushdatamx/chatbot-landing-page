---
const checkoutUrl = "https://pay.hotmart.com/R104883023O?bid=1773453606789";
---

<!-- Floating CTA Button -->
<a
  href={checkoutUrl}
  target="_blank"
  rel="noopener noreferrer"
  onclick={`trackInitiateCheckout(); setTimeout(function(){window.open('${checkoutUrl}','_blank')}, 300); return false;`}
  id="floating-cta"
  class="fixed bottom-6 right-6 z-50 inline-flex items-center gap-2 bg-primary-500 hover:bg-primary-600 text-white font-bold px-6 py-4 rounded-full shadow-2xl transition-all duration-300 hover:scale-105 hover:shadow-primary-500/40 opacity-0 translate-y-4 pointer-events-none"
  aria-label="Comprar por $49"
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
  </svg>
  <span class="hidden sm:inline">Comprar por $49</span>
  <span class="sm:hidden">$49</span>
</a>

<script>
  const floatingCTA = document.getElementById('floating-cta');
  const heroSection = document.getElementById('hero-visual')?.closest('section');

  if (floatingCTA && heroSection) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            floatingCTA.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
            floatingCTA.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
          } else {
            floatingCTA.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
            floatingCTA.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
          }
        });
      },
      { threshold: 0 }
    );

    observer.observe(heroSection);
  }
</script>
