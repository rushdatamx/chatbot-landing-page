---
const testimonials = [
  {
    name: "Carolina M.",
    business: "Salón de belleza",
    rating: 5,
    text: "Antes perdía citas porque no podía responder WhatsApp mientras atendía clientas. Ahora mi chatbot agenda citas las 24 horas. La semana pasada recibí 3 reservaciones a las 11 PM.",
  },
  {
    name: "Roberto S.",
    business: "Tienda de electrónica",
    rating: 5,
    text: "Pensé que necesitaba un programador para tener un chatbot. El curso es literalmente copiar y pegar. Lo tuve funcionando en un fin de semana. Mis clientes no pueden creer que respondo en segundos.",
  },
  {
    name: "Ana L.",
    business: "Restaurante",
    rating: 5,
    text: "El chatbot maneja los pedidos por WhatsApp y cobra con tarjeta automáticamente. Ya no necesito a alguien contestando mensajes todo el día. Se paga solo con lo que ahorro.",
  }
];
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Lo que dicen nuestros estudiantes
      </h2>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((testimonial) => (
        <div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg transition-all duration-300">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array(testimonial.rating).fill(0).map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-gray-700 mb-6 leading-relaxed">
            "{testimonial.text}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center">
              <span class="text-primary-600 font-semibold text-lg">
                {testimonial.name.split(' ').map(n => n[0]).join('')}
              </span>
            </div>
            <div>
              <p class="font-semibold text-gray-900">{testimonial.name}</p>
              <p class="text-sm text-gray-500">{testimonial.business}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Metrics Bar -->
    <div class="mt-12 text-center">
      <div class="inline-flex flex-wrap items-center justify-center gap-6 bg-white rounded-full px-8 py-4 shadow-md">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-gray-700 font-medium">Disponible <span class="font-bold">24/7</span></span>
        </div>
        <span class="text-gray-300">|</span>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <span class="text-gray-700 font-medium">Listo en <span class="font-bold">14 días</span></span>
        </div>
        <span class="text-gray-300">|</span>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-gray-700 font-medium">Costo mensual: <span class="font-bold">~$25-50/mes</span></span>
        </div>
      </div>
    </div>
  </div>
</section>
