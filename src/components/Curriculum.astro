---
const modules = [
  {
    number: "0",
    title: "Bienvenida y Visión",
    lessons: 2,
    outcome: "Entiendes exactamente qué vas a construir y cómo funciona",
    items: ["Lo que vas a construir", "Mentalidad del implementador"]
  },
  {
    number: "1",
    title: "Cuentas y Arquitectura",
    lessons: 7,
    outcome: "Creas las 5 cuentas que necesitas (todas gratuitas o con plan mínimo)",
    items: ["Cómo funcionan las piezas", "Crear cuenta Supabase", "Crear cuenta Twilio", "Crear cuenta OpenAI", "Crear cuenta n8n", "Crear cuenta Stripe", "Resumen de credenciales y costos"]
  },
  {
    number: "2",
    title: "Base de Datos",
    lessons: 4,
    outcome: "Configuras tu base de datos y cargas tu catálogo de productos",
    items: ["Entender la estructura de datos", "Crear tablas con SQL", "Cargar catálogo de productos", "Supabase Studio: tu dashboard"]
  },
  {
    number: "3",
    title: "El Cerebro del Chatbot (IA)",
    lessons: 5,
    outcome: "Despliegas el chatbot con IA y lo personalizas para tu marca",
    items: ["Qué es una Edge Function", "Personalizar la configuración", "Personalizar el prompt", "Desplegar el chatbot", "Desplegar funciones de pago"]
  },
  {
    number: "4",
    title: "Conectar Todo",
    lessons: 4,
    outcome: "Tu chatbot responde en WhatsApp por primera vez",
    items: ["Importar workflow principal", "Configurar credenciales en n8n", "Conectar Twilio con n8n", "Guía: Pruebas y solución de problemas"]
  },
  {
    number: "5",
    title: "Pagos con Stripe",
    lessons: 4,
    outcome: "Integras Stripe para cobrar con tarjeta automáticamente",
    items: ["Configurar webhook de Stripe", "Probar un pago completo", "Notificación de pago por WhatsApp", "Entender el flujo de dinero"]
  },
  {
    number: "6",
    title: "Lanzamiento a Producción",
    lessons: 3,
    outcome: "Lanzas con tu propio número de WhatsApp y consigues tus primeros clientes",
    items: ["De sandbox a producción", "Checklist final de lanzamiento", "Estrategia para primeros clientes"]
  },
  {
    number: "7",
    title: "Bonus — Funciones Avanzadas",
    lessons: 3,
    outcome: "Imágenes de productos, reportes de ventas con SQL, optimización de prompt",
    items: ["Enviar imágenes de productos", "Reportes de negocio con SQL", "Mejorar tu prompt con datos reales"]
  }
];

const totalLessons = modules.reduce((sum, m) => sum + m.lessons, 0);
---

<section id="contenido" class="py-16 md:py-24 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Lo que incluye
      </h2>
      <p class="text-xl text-gray-600">
        8 módulos. {totalLessons} lecciones. Todo paso a paso.
      </p>
    </div>

    <!-- Module Accordions -->
    <div class="space-y-4">
      {modules.map((mod) => (
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-gray-100 transition-colors">
            <div class="flex items-center gap-4">
              <span class="w-10 h-10 bg-primary-500 text-white rounded-full flex items-center justify-center font-bold text-sm flex-shrink-0">
                {mod.number}
              </span>
              <div>
                <h3 class="text-lg font-semibold text-gray-900">
                  {mod.title}
                </h3>
                <p class="text-sm text-gray-500">
                  {mod.lessons} lecciones — {mod.outcome}
                </p>
              </div>
            </div>
            <span class="flex-shrink-0 w-8 h-8 bg-primary-100 rounded-full flex items-center justify-center text-primary-600 group-open:rotate-180 transition-transform duration-300 ml-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </span>
          </summary>
          <div class="px-6 pb-6">
            <ul class="space-y-2 ml-14">
              {mod.items.map((item) => (
                <li class="flex items-center gap-3 text-gray-600">
                  <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </details>
      ))}
    </div>

    <!-- Summary Bar -->
    <div class="mt-8 bg-primary-50 rounded-2xl p-6 text-center">
      <div class="flex flex-wrap justify-center gap-6 text-primary-700 font-semibold">
        <span>{totalLessons} lecciones</span>
        <span class="text-primary-300">|</span>
        <span>7+ horas de contenido</span>
        <span class="text-primary-300">|</span>
        <span>Acceso de por vida</span>
      </div>
    </div>
  </div>
</section>
