---
const checkoutUrl = "https://pay.hotmart.com/R104883023O?bid=1773453606789";
---

<section class="relative overflow-hidden">
  <!-- Background: Navy gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-secondary-900 via-secondary-800 to-primary-900"></div>

  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.4&quot;%3E%3Ccircle cx=&quot;30&quot; cy=&quot;30&quot; r=&quot;4&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 lg:py-32">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left Column: Content -->
      <div class="text-center lg:text-left">
        <!-- Launch Badge -->
        <div class="inline-flex items-center gap-2 bg-primary-500/20 backdrop-blur-sm text-white px-4 py-2 rounded-full text-sm font-medium mb-6 border border-primary-400/30">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary-500"></span>
          </span>
          <span>Precio de lanzamiento — $49 USD</span>
        </div>

        <!-- H1 -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
          Tu Vendedor
          <span class="text-primary-400">24/7</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-xl md:text-2xl text-white/90 mb-4 max-w-xl mx-auto lg:mx-0">
          Crea tu chatbot de WhatsApp con IA que atiende clientes, cotiza productos y cobra con tarjeta —
          <span class="font-semibold text-primary-400">sin programar</span>.
        </p>

        <!-- Supporting text -->
        <p class="text-lg text-white/70 mb-8 max-w-xl mx-auto lg:mx-0">
          El sistema paso a paso para tener tu chatbot vendiendo
          <span class="font-semibold">en 14 días</span>.
        </p>

        <!-- CTA -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-6">
          <a
            href={checkoutUrl}
            target="_blank"
            rel="noopener noreferrer"
            onclick={`trackInitiateCheckout(); setTimeout(function(){window.open('${checkoutUrl}','_blank')}, 300); return false;`}
            class="group inline-flex items-center justify-center gap-3 bg-primary-500 hover:bg-primary-600 text-white font-bold px-8 py-5 rounded-full text-xl transition-all duration-300 hover:scale-105 shadow-2xl hover:shadow-primary-500/40"
          >
            Quiero mi Chatbot
            <svg class="w-6 h-6 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
        </div>

        <!-- Micro-copy -->
        <p class="text-sm text-white/50 mb-8">
          Pago único · Acceso de por vida · Acceso inmediato
        </p>

        <!-- Trust Badges -->
        <div class="flex flex-wrap justify-center lg:justify-start gap-3 text-white/80">
          <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm px-3 py-2 rounded-lg">
            <svg class="w-5 h-5 text-primary-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm font-medium">Sin programar</span>
          </div>
          <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm px-3 py-2 rounded-lg">
            <svg class="w-5 h-5 text-primary-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm font-medium">27 videos paso a paso</span>
          </div>
          <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm px-3 py-2 rounded-lg">
            <svg class="w-5 h-5 text-primary-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm font-medium">Código listo para usar</span>
          </div>
        </div>
      </div>

      <!-- Right Column: WhatsApp Chat Mockup -->
      <div class="relative hidden lg:block" id="hero-visual">
        <div class="relative w-full max-w-md mx-auto">
          <!-- Chat Card -->
          <div class="bg-white rounded-2xl shadow-2xl p-6 transform rotate-1 hover:rotate-0 transition-transform duration-300">
            <!-- Chat Header -->
            <div class="flex items-center gap-3 mb-4 pb-4 border-b">
              <div class="w-12 h-12 bg-primary-500 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
              <div>
                <p class="font-bold text-gray-900">Sunny's Coffee Shop</p>
                <p class="text-xs text-green-600 flex items-center gap-1">
                  <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                  Chatbot IA activo
                </p>
              </div>
            </div>

            <!-- Chat Messages -->
            <div class="space-y-3">
              <div class="flex justify-end">
                <div class="bg-green-100 text-gray-800 px-4 py-2 rounded-2xl rounded-tr-md text-sm max-w-[80%]">
                  Hola, quiero un Caramel Latte
                </div>
              </div>
              <div class="flex justify-start">
                <div class="bg-gray-100 text-gray-800 px-4 py-2 rounded-2xl rounded-tl-md text-sm max-w-[80%]">
                  El Caramel Latte cuesta $75 MXN. ¿Te envío el link de pago?
                </div>
              </div>
              <div class="flex justify-end">
                <div class="bg-green-100 text-gray-800 px-4 py-2 rounded-2xl rounded-tr-md text-sm max-w-[80%]">
                  ¡Sí, por favor!
                </div>
              </div>
              <div class="flex justify-start">
                <div class="bg-gray-100 text-gray-800 px-4 py-2 rounded-2xl rounded-tl-md text-sm max-w-[80%]">
                  Aquí está tu link de pago seguro: 💳
                </div>
              </div>
            </div>

            <!-- Typing Indicator -->
            <div class="mt-3 flex items-center gap-2 text-gray-500 text-sm">
              <div class="flex gap-1">
                <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0ms;"></span>
                <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 150ms;"></span>
                <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 300ms;"></span>
              </div>
              <span>Generando link de pago...</span>
            </div>
          </div>

          <!-- Floating Badge: AI 24/7 -->
          <div class="absolute -top-4 -right-4 bg-primary-500 text-white rounded-full px-4 py-2 font-bold text-sm shadow-lg animate-bounce" style="animation-duration: 2s;">
            IA 24/7
          </div>

          <!-- Floating Badge: Cobro automático -->
          <div class="absolute -bottom-4 -left-4 bg-white rounded-lg shadow-xl p-3">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 bg-primary-500 rounded-full flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs text-gray-500">Cobro automático</p>
                <p class="font-bold text-gray-900 text-sm">Stripe</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Wave Separator -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
      <path d="M0 120L60 110C120 100 240 80 360 70C480 60 600 60 720 65C840 70 960 80 1080 85C1200 90 1320 90 1380 90L1440 90V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
    </svg>
  </div>
</section>
