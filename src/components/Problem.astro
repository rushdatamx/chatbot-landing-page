---
const problems = [
  {
    text: "Pierdes ventas porque no puedes responder WhatsApp a las 11 de la noche",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>`
  },
  {
    text: 'Pasas horas contestando las mismas preguntas: "¿Cuánto cuesta?", "¿Tienen disponible?", "¿Hacen envíos?"',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>`
  },
  {
    text: "Tus competidores ya usan IA y tú sigues respondiendo manualmente",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
    </svg>`
  },
  {
    text: "Quisieras automatizar pero los desarrolladores cobran $5,000-$15,000 USD por un chatbot",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>`
  }
];
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        ¿Te suena familiar?
      </h2>
    </div>

    <!-- Problem Cards -->
    <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {problems.map((problem) => (
        <div class="flex items-start gap-4 p-6 bg-red-50 rounded-2xl border border-red-100">
          <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center text-red-500 flex-shrink-0">
            <Fragment set:html={problem.icon} />
          </div>
          <p class="text-gray-700 text-lg leading-relaxed">
            {problem.text}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
