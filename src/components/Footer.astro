---
const config = {
  brand: "RushData",
  email: "mario@rushdata.com.mx",
};

const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-white">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <img src="/images/rushdata-logo.png" alt={config.brand} class="h-10 w-auto brightness-0 invert" />
        </div>
        <p class="text-gray-400 max-w-sm">
          Herramientas y educación para automatizar tu negocio con inteligencia artificial.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-semibold mb-4">Enlaces</h3>
        <ul class="space-y-3 text-gray-400">
          <li>
            <a href="#como-funciona" class="hover:text-white transition-colors">Cómo Funciona</a>
          </li>
          <li>
            <a href="#contenido" class="hover:text-white transition-colors">Contenido</a>
          </li>
          <li>
            <a href="#precio" class="hover:text-white transition-colors">Precio</a>
          </li>
          <li>
            <a href="#faq" class="hover:text-white transition-colors">Preguntas Frecuentes</a>
          </li>
          <li>
            <a href="/privacidad" class="hover:text-white transition-colors">Aviso de Privacidad</a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-lg font-semibold mb-4">Contacto</h3>
        <ul class="space-y-3 text-gray-400">
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href={`mailto:${config.email}`} class="hover:text-white transition-colors">
              {config.email}
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-gray-400 text-sm">
        <p>
          &copy; {currentYear} {config.brand}. Todos los derechos reservados.
        </p>
        <p>
          <a href="/privacidad" class="hover:text-white transition-colors">
            Aviso de Privacidad
          </a>
        </p>
      </div>
    </div>
  </div>
</footer>
