---
const yesItems = [
  "Tienes un negocio (tienda, restaurante, salón, clínica, o cualquier negocio con productos/servicios)",
  "Quieres que un chatbot atienda tus clientes por WhatsApp las 24 horas",
  "No sabes programar y no quieres aprender — solo quieres copiar, pegar y personalizar",
  "Estás dispuesto a invertir ~$25-50 USD/mes en las herramientas para operarlo",
  "Quieres dejar de perder ventas por no responder a tiempo",
];

const noItems = [
  "Buscas un chatbot gratis (las herramientas tienen un costo mensual mínimo)",
  "No tienes un negocio o productos que vender",
  "Quieres resultados sin seguir los pasos del curso",
];
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        ¿Es para ti?
      </h2>
    </div>

    <!-- Two Column Layout -->
    <div class="grid md:grid-cols-2 gap-8">
      <!-- YES Column -->
      <div class="bg-green-50 border-2 border-green-200 rounded-2xl p-8">
        <h3 class="text-xl font-bold text-green-700 mb-6 flex items-center gap-2">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          Esto es para ti si:
        </h3>
        <ul class="space-y-4">
          {yesItems.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-gray-700">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- NO Column -->
      <div class="bg-red-50 border-2 border-red-200 rounded-2xl p-8">
        <h3 class="text-xl font-bold text-red-700 mb-6 flex items-center gap-2">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
          Esto NO es para ti si:
        </h3>
        <ul class="space-y-4">
          {noItems.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
              </svg>
              <span class="text-gray-700">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
