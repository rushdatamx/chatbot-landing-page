---
const checkoutUrl = "https://pay.hotmart.com/R104883023O?bid=1773453606789";
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <img
          src="/images/rushdata-logo.png"
          alt="RushData"
          class="h-9 md:h-11 w-auto"
        />
      </a>

      <!-- Nav Links (hidden on mobile) -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="#como-funciona" class="text-gray-600 hover:text-primary-500 text-sm font-medium transition-colors">Cómo Funciona</a>
        <a href="#contenido" class="text-gray-600 hover:text-primary-500 text-sm font-medium transition-colors">Contenido</a>
        <a href="#precio" class="text-gray-600 hover:text-primary-500 text-sm font-medium transition-colors">Precio</a>
        <a href="#faq" class="text-gray-600 hover:text-primary-500 text-sm font-medium transition-colors">FAQ</a>
      </nav>

      <!-- CTA Button -->
      <a
        href={checkoutUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-primary-500 hover:bg-primary-600 text-white font-semibold px-4 py-2 md:px-6 md:py-3 rounded-full transition-all duration-300 hover:scale-105 shadow-lg hover:shadow-xl text-sm md:text-base"
      >
        <span>Empezar Ahora</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 md:h-20"></div>
